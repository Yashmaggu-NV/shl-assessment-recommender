# SHL Assessment Recommender — Environment Variables
# Copy this file to .env and fill in your values.
#
# cp .env.example .env

# ---------------------------------------------------------------------------
# Required: xAI (Grok) API key for LLM calls
# Get a key at: https://console.x.ai
# ---------------------------------------------------------------------------
XAI_API_KEY=your_xai_api_key_here

# ---------------------------------------------------------------------------
# Optional: Server configuration
# ---------------------------------------------------------------------------
PORT=8000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Optional: Grok model override
# Default: grok-3-mini-fast (fast, cost-effective)
# Alternative: grok-3-mini (higher quality)
# ---------------------------------------------------------------------------
# GROK_MODEL=grok-3-mini-fast
